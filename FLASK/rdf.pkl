from pathlib import Path
import pickle

import numpy as np
import pandas as pd
from flask import Flask, jsonify, render_template, request

APP_DIR = Path(__file__).resolve().parent
app = Flask(
    __name__,
    template_folder=str(APP_DIR / "templates"),
    static_folder=str(APP_DIR / "static"),
)

BASE_DIR = Path(__file__).resolve().parent.parent
DELIVERABLES_DIR = BASE_DIR / "_deliverables"
MODEL_PATH = DELIVERABLES_DIR / "best_model_epic4_random_forest.pkl"
SCALER_PATH = DELIVERABLES_DIR / "scaler_epic3.pkl"
LOCAL_MODEL_PATH = APP_DIR / "rdf.pkl"
LOCAL_SCALER_PATH = APP_DIR / "scale1.pkl"

FEATURE_COLUMNS = [
    "Gender",
    "Married",
    "Dependents",
    "Education",
    "Self_Employed",
    "ApplicantIncome",
    "CoapplicantIncome",
    "LoanAmount",
    "Loan_Amount_Term",
    "Credit_History",
    "Property_Area",
]

NUMERIC_COLUMNS = ["ApplicantIncome", "CoapplicantIncome", "LoanAmount", "Loan_Amount_Term"]

MAPPINGS = {
    "Gender": {"Male": 0, "Female": 1},
    "Married": {"No": 0, "Yes": 1},
    "Dependents": {"0": 0, "1": 1, "2": 2, "3": 3, "3+": 3},
    "Education": {"Not Graduate": 0, "Graduate": 1},
    "Self_Employed": {"No": 0, "Yes": 1},
    "Credit_History": {"0": 0, "1": 1},
    "Property_Area": {"Rural": 0, "Semiurban": 1, "Urban": 2},
}

MODEL = pickle.load(open(LOCAL_MODEL_PATH, "rb"))
SCALER = pickle.load(open(LOCAL_SCALER_PATH, "rb"))


def transform_input(form_data):
    values = []

    for field in FEATURE_COLUMNS:
        value = form_data.get(field)
        if value is None or value == "":
            raise ValueError(f"Missing value for {field}")

        if field in MAPPINGS:
            values.append(MAPPINGS[field][value])
        elif field in NUMERIC_COLUMNS:
            values.append(float(value))
        else:
            values.append(value)

    input_array = np.array([values], dtype=float)
    frame = pd.DataFrame(input_array, columns=FEATURE_COLUMNS)
    frame.loc[:, NUMERIC_COLUMNS] = SCALER.transform(frame[NUMERIC_COLUMNS])
    return frame


def predict_loan_approval(form_data):
    features = transform_input(form_data)
    predicted_class = int(MODEL.predict(features)[0])
    probability = float(MODEL.predict_proba(features)[0][1])
    return predicted_class, probability


@app.route("/api/predict", methods=["POST"])
def api_predict():
    try:
        prediction, probability = predict_loan_approval(request.form)
        return jsonify(
            {
                "approved": bool(prediction == 1),
                "probability": round(probability * 100, 2),
                "confidence_band": round(abs(probability - 0.5) * 200, 2),
            }
        )
    except Exception as exc:
        return jsonify({"error": str(exc)}), 400


@app.route("/")
def home():
    return render_template("home.html")


@app.route("/apply")
def apply():
    return render_template("predict.html")


@app.route("/predict", methods=["GET", "POST"])
def predict():
    if request.method == "POST":
        try:
            prediction, probability = predict_loan_approval(request.form)
            approved = prediction == 1
            return render_template(
                "submit.html",
                approved=approved,
                probability=round(probability * 100, 2),
                confidence_band=round(abs(probability - 0.5) * 200, 2),
            )
        except Exception as exc:
            return render_template("submit.html", error=str(exc))

    return render_template("predict.html")


@app.route("/submit", methods=["POST"])
def submit():
    return predict()


if __name__ == "__main__":
    app.run(debug=True, host="127.0.0.1", port=5000)
