   "source": [
    "# Epic 4: Model Building\n",
    "\n",
    "## Overview\n",
    "This notebook implements and evaluates multiple machine learning models for loan approval prediction:\n",
    "- Decision Tree\n",
    "- Random Forest\n",
    "- K-Nearest Neighbors (KNN)\n",
    "- XGBoost\n",
    "\n",
    "We will train, evaluate, compare, and save the best-performing model."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "fb3ca44d",
   "metadata": {},
   "source": [
    "## 1. Import Required Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "9e6376b5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ All libraries imported successfully!\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "import pickle\n",
    "import joblib\n",
    "from datetime import datetime\n",
    "\n",
    "# Sklearn imports\n",
    "from sklearn.tree import DecisionTreeClassifier\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n",
    "from sklearn.metrics import confusion_matrix, classification_report, roc_auc_score, roc_curve\n",
    "from sklearn.metrics import auc\n",
    "from sklearn.model_selection import cross_val_score\n",
    "\n",
    "# XGBoost import\n",
    "import xgboost as xgb\n",
    "\n",
    "# Set visualization style\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "\n",
    "print('✓ All libraries imported successfully!')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "75ad6acc",
   "metadata": {},
   "source": [
    "## 2. Load Preprocessed Data from Epic 3"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "e3cd292a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Data Loaded Successfully!\n",
      "\n",
      "Training set shape: (675, 11)\n",
      "Test set shape: (169, 11)\n",
      "\n",
      "Target variable distribution (Training):\n",
      "1    338\n",
      "0    337\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "# Define paths\n",
    "base_path = Path.cwd().parent\n",
    "deliverables_path = base_path / '_deliverables'\n",
    "\n",
    "# Load preprocessed data\n",
    "X_train = pd.read_csv(deliverables_path / 'X_train_epic3.csv')\n",
    "X_test = pd.read_csv(deliverables_path / 'X_test_epic3.csv')\n",
    "y_train = pd.read_csv(deliverables_path / 'y_train_epic3.csv').values.ravel()\n",
    "y_test = pd.read_csv(deliverables_path / 'y_test_epic3.csv').values.ravel()\n",
    "\n",
    "print('Data Loaded Successfully!')\n",
    "print(f'\\nTraining set shape: {X_train.shape}')\n",
    "print(f'Test set shape: {X_test.shape}')\n",
    "print(f'\\nTarget variable distribution (Training):')\n",
    "print(pd.Series(y_train).value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e94826ff",
   "metadata": {},
   "source": [
    "## 3. Decision Tree Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "fc4b5d6b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "============================================================\n",
      "DECISION TREE MODEL PERFORMANCE\n",
      "============================================================\n",
      "Training Accuracy:  0.9422\n",
      "Testing Accuracy:   0.7988\n",
      "Precision:          0.7976\n",
      "Recall:             0.7976\n",
      "F1-Score:           0.7976\n",
      "ROC-AUC Score:      0.8073\n",
      "\n",
      "Confusion Matrix:\n",
      "[[68 17]\n",
      " [17 67]]\n"
     ]
    }
   ],
   "source": [
    "def train_decision_tree(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Train and evaluate Decision Tree model\"\"\"\n",
    "    \n",
    "    # Initialize and train model\n",
    "    dt_model = DecisionTreeClassifier(random_state=42, max_depth=10)\n",
    "    dt_model.fit(X_train, y_train)\n",
    "    \n",
    "    # Predictions\n",
    "    y_train_pred = dt_model.predict(X_train)\n",
    "    y_test_pred = dt_model.predict(X_test)\n",
    "    \n",
    "    # Get probabilities for ROC-AUC\n",
    "    y_test_proba = dt_model.predict_proba(X_test)[:, 1]\n",
    "    \n",
    "    # Calculate metrics\n",
    "    train_acc = accuracy_score(y_train, y_train_pred)\n",
    "    test_acc = accuracy_score(y_test, y_test_pred)\n",
    "    precision = precision_score(y_test, y_test_pred)\n",
    "    recall = recall_score(y_test, y_test_pred)\n",
    "    f1 = f1_score(y_test, y_test_pred)\n",
    "    roc_auc = roc_auc_score(y_test, y_test_proba)\n",
    "    \n",
    "    # Confusion matrix\n",
    "    cm = confusion_matrix(y_test, y_test_pred)\n",
    "    \n",
    "    return {\n",
    "        'model': dt_model,\n",
    "        'train_accuracy': train_acc,\n",
    "        'test_accuracy': test_acc,\n",
    "        'precision': precision,\n",
    "        'recall': recall,\n",
    "        'f1_score': f1,\n",
    "        'roc_auc': roc_auc,\n",
    "        'confusion_matrix': cm,\n",
    "        'y_pred': y_test_pred,\n",
    "        'y_proba': y_test_proba\n",
    "    }\n",
    "\n",
    "# Train Decision Tree\n",
    "dt_results = train_decision_tree(X_train, X_test, y_train, y_test)\n",
    "\n",
    "print('='*60)\n",
    "print('DECISION TREE MODEL PERFORMANCE')\n",
    "print('='*60)\n",
    "print(f'Training Accuracy:  {dt_results[\"train_accuracy\"]:.4f}')\n",
    "print(f'Testing Accuracy:   {dt_results[\"test_accuracy\"]:.4f}')\n",
    "print(f'Precision:          {dt_results[\"precision\"]:.4f}')\n",
    "print(f'Recall:             {dt_results[\"recall\"]:.4f}')\n",
    "print(f'F1-Score:           {dt_results[\"f1_score\"]:.4f}')\n",
    "print(f'ROC-AUC Score:      {dt_results[\"roc_auc\"]:.4f}')\n",
    "print('\\nConfusion Matrix:')\n",
    "print(dt_results['confusion_matrix'])"
   ]
  },
