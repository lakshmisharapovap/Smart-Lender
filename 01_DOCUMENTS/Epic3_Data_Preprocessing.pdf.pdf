   ],
   "source": [
    "# Select best model based on ROC-AUC\n",
    "models_dict = {\n",
    "    'Decision Tree': dt_results,\n",
    "    'Random Forest': rf_results,\n",
    "    'KNN': knn_results,\n",
    "    'XGBoost': xgb_results\n",
    "}\n",
    "\n",
    "best_result = models_dict[best_model_name]\n",
    "best_model = best_result['model']\n",
    "\n",
    "# Save best model\n",
    "model_save_path = deliverables_path / f'best_model_epic4_{best_model_name.lower().replace(\" \", \"_\")}.pkl'\n",
    "joblib.dump(best_model, model_save_path)\n",
    "print(f'✓ Best model saved: {model_save_path.name}')\n",
    "\n",
    "# Save all models comparison results\n",
    "comparison_save_path = deliverables_path / 'epic4_model_comparison.csv'\n",
    "comparison_df.to_csv(comparison_save_path, index=False)\n",
    "print(f'✓ Model comparison results saved: {comparison_save_path.name}')\n",
    "\n",
    "# Create detailed report\n",
    "report = f\"\"\"# Epic 4: Model Building - Detailed Report\n",
    "\n",
    "## Executive Summary\n",
    "- **Best Model**: {best_model_name}\n",
    "- **ROC-AUC Score**: {best_roc_auc:.4f}\n",
    "- **Test Accuracy**: {best_result['test_accuracy']:.4f}\n",
    "- **Precision**: {best_result['precision']:.4f}\n",
    "- **Recall**: {best_result['recall']:.4f}\n",
    "- **F1-Score**: {best_result['f1_score']:.4f}\n",
    "\n",
    "## Model Performance Comparison\n",
    "\n",
    "### Decision Tree\n",
    "- Train Accuracy: {dt_results['train_accuracy']:.4f}\n",
    "- Test Accuracy: {dt_results['test_accuracy']:.4f}\n",
    "- ROC-AUC: {dt_results['roc_auc']:.4f}\n",
    "- F1-Score: {dt_results['f1_score']:.4f}\n",
    "\n",
    "### Random Forest\n",
    "- Train Accuracy: {rf_results['train_accuracy']:.4f}\n",
    "- Test Accuracy: {rf_results['test_accuracy']:.4f}\n",
    "- ROC-AUC: {rf_results['roc_auc']:.4f}\n",
    "- F1-Score: {rf_results['f1_score']:.4f}\n",
    "\n",
    "### K-Nearest Neighbors (KNN)\n",
    "- Optimal k: {knn_results['best_k']}\n",
    "- Train Accuracy: {knn_results['train_accuracy']:.4f}\n",
    "- Test Accuracy: {knn_results['test_accuracy']:.4f}\n",
    "- ROC-AUC: {knn_results['roc_auc']:.4f}\n",
    "- F1-Score: {knn_results['f1_score']:.4f}\n",
    "\n",
    "### XGBoost\n",
    "- Train Accuracy: {xgb_results['train_accuracy']:.4f}\n",
    "- Test Accuracy: {xgb_results['test_accuracy']:.4f}\n",
    "- ROC-AUC: {xgb_results['roc_auc']:.4f}\n",
    "- F1-Score: {xgb_results['f1_score']:.4f}\n",
    "\n",
    "## Key Findings\n",
    "\n",
    "1. **Best Performing Model**: {best_model_name} achieved the highest ROC-AUC score of {best_roc_auc:.4f}\n",
    "2. **Generalization**: Test accuracy is {best_result['test_accuracy']:.4f}, indicating good generalization\n",
    "3. **Precision-Recall Balance**: F1-Score of {best_result['f1_score']:.4f} shows balanced performance\n",
    "\n",
    "## Recommendations\n",
    "\n",
    "- **Deployment Model**: {best_model_name} is recommended for deployment\n",
    "- **Next Steps**: Integrate {best_model_name} into Flask application for production\n",
    "- **Monitoring**: Track model performance metrics post-deployment\n",
    "\n",
    "---\n",
    "Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n",
    "\"\"\"\n",
    "\n",
    "report_save_path = deliverables_path / 'Epic4_Model_Building_Report.md'\n",
    "with open(report_save_path, 'w') as f:\n",
    "    f.write(report)\n",
    "print(f'✓ Detailed report saved: {report_save_path.name}')\n",
