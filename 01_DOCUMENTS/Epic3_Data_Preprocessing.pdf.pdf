    "# Select best model based on ROC-AUC score\n",
    "models_dict = {\n",
    "    'Decision Tree': dt_results,\n",
    "    'Random Forest': rf_results,\n",
    "    'KNN': knn_results,\n",
    "    'XGBoost': xgb_results\n",
    "}\n",
    "\n",
    "best_model_name = comparison_df.loc[comparison_df['ROC-AUC'].idxmax(), 'Model']\n",
    "best_result = models_dict[best_model_name]\n",
    "best_model = best_result['model']\n",
    "\n",
    "print('='*80)\n",
    "print('SAVING THE BEST MODEL')\n",
    "print('='*80)\n",
    "print(f'\\nBest Model: {best_model_name}')\n",
    "print(f'ROC-AUC Score: {best_result[\"roc_auc\"]:.4f}')\n",
    "print(f'Test Accuracy: {best_result[\"test_accuracy\"]:.4f}')\n",
    "\n",
    "# Save best model using pickle.dump()\n",
    "model_filename = deliverables_path / f'best_model_epic4_{best_model_name.lower().replace(\" \", \"_\")}.pkl'\n",
    "\n",
    "with open(model_filename, 'wb') as f:\n",
    "    pickle.dump(best_model, f)\n",
    "\n",
    "print(f'\\n✓ Model saved successfully!')\n",
    "print(f'  File: {model_filename.name}')\n",
    "print(f'  Path: {model_filename}')\n",
    "\n",
    "print('\\nThis model can be loaded in Flask using:')\n",
    "print('  with open(\"best_model_epic4.pkl\", \"rb\") as f:')\n",
    "print('      model = pickle.load(f)')\n",
    "print('  prediction = model.predict(new_applicant_features)')\n",
    "print('='*80)"
