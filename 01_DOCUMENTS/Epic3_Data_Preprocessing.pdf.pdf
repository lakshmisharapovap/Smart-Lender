    "# Plot 1: Accuracy Comparison\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# Test Accuracy\n",
    "ax1 = axes[0, 0]\n",
    "models = comparison_df['Model']\n",
    "test_acc = comparison_df['Test Accuracy']\n",
    "colors = ['#FF6B6B' if x != best_model_name else '#51CF66' for x in models]\n",
    "ax1.bar(models, test_acc, color=colors, alpha=0.7, edgecolor='black')\n",
    "ax1.set_ylabel('Accuracy', fontsize=12, fontweight='bold')\n",
    "ax1.set_title('Test Accuracy Comparison', fontsize=13, fontweight='bold')\n",
    "ax1.set_ylim([0, 1])\n",
    "for i, v in enumerate(test_acc):\n",
    "    ax1.text(i, v + 0.02, f'{v:.4f}', ha='center', fontweight='bold')\n",
    "\n",
    "# ROC-AUC Comparison\n",
    "ax2 = axes[0, 1]\n",
    "roc_auc = comparison_df['ROC-AUC']\n",
    "ax2.bar(models, roc_auc, color=colors, alpha=0.7, edgecolor='black')\n",
    "ax2.set_ylabel('ROC-AUC Score', fontsize=12, fontweight='bold')\n",
    "ax2.set_title('ROC-AUC Score Comparison', fontsize=13, fontweight='bold')\n",
    "ax2.set_ylim([0, 1])\n",
    "for i, v in enumerate(roc_auc):\n",
    "    ax2.text(i, v + 0.02, f'{v:.4f}', ha='center', fontweight='bold')\n",
    "\n",
    "# F1-Score Comparison\n",
    "ax3 = axes[1, 0]\n",
    "f1 = comparison_df['F1-Score']\n",
    "ax3.bar(models, f1, color=colors, alpha=0.7, edgecolor='black')\n",
    "ax3.set_ylabel('F1-Score', fontsize=12, fontweight='bold')\n",
    "ax3.set_title('F1-Score Comparison', fontsize=13, fontweight='bold')\n",
    "ax3.set_ylim([0, 1])\n",
    "for i, v in enumerate(f1):\n",
    "    ax3.text(i, v + 0.02, f'{v:.4f}', ha='center', fontweight='bold')\n",
    "\n",
    "# Precision vs Recall\n",
    "ax4 = axes[1, 1]\n",
    "x = np.arange(len(models))\n",
    "width = 0.35\n",
    "precision = comparison_df['Precision']\n",
    "recall = comparison_df['Recall']\n",
    "ax4.bar(x - width/2, precision, width, label='Precision', alpha=0.8, edgecolor='black')\n",
    "ax4.bar(x + width/2, recall, width, label='Recall', alpha=0.8, edgecolor='black')\n",
    "ax4.set_ylabel('Score', fontsize=12, fontweight='bold')\n",
    "ax4.set_title('Precision vs Recall', fontsize=13, fontweight='bold')\n",
    "ax4.set_xticks(x)\n",
    "ax4.set_xticklabels(models)\n",
    "ax4.legend()\n",
    "ax4.set_ylim([0, 1])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../_deliverables/epic4_model_comparison.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print('✓ Model comparison visualization saved!')"
