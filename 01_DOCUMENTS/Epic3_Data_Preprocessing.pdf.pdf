    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Simplified model functions defined!\n"
     ]
    }
   ],
   "source": [
    "# Simplified model functions following a simpler pattern\n",
    "\n",
    "def decisionTree(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Simple Decision Tree implementation\"\"\"\n",
    "    model = DecisionTreeClassifier(random_state=42, max_depth=10)\n",
    "    model.fit(X_train, y_train)\n",
    "    \n",
    "    y_tr = model.predict(X_train)\n",
    "    yPred = model.predict(X_test)\n",
    "    \n",
    "    print(accuracy_score(y_tr, y_train))\n",
    "    print(accuracy_score(yPred, y_test))\n",
    "    \n",
    "    return model, confusion_matrix(y_test, yPred), classification_report(y_test, yPred)\n",
    "\n",
    "def RandomForest(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Simple Random Forest implementation\"\"\"\n",
    "    model = RandomForestClassifier(n_estimators=100, random_state=42)\n",
    "    model.fit(X_train, y_train)\n",
    "    \n",
    "    y_tr = model.predict(X_train)\n",
    "    yPred = model.predict(X_test)\n",
    "    \n",
    "    print(accuracy_score(y_tr, y_train))\n",
    "    print(accuracy_score(yPred, y_test))\n",
    "    \n",
    "    return model, confusion_matrix(y_test, yPred), classification_report(y_test, yPred)\n",
    "\n",
    "def KNN(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Simple KNN implementation\"\"\"\n",
    "    model = KNeighborsClassifier(n_neighbors=5)\n",
    "    model.fit(X_train, y_train)\n",
    "    \n",
    "    y_tr = model.predict(X_train)\n",
    "    yPred = model.predict(X_test)\n",
    "    \n",
    "    print(accuracy_score(y_tr, y_train))\n",
    "    print(accuracy_score(yPred, y_test))\n",
    "    \n",
    "    return model, confusion_matrix(y_test, yPred), classification_report(y_test, yPred)\n",
    "\n",
    "def XGB(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Simple Gradient Boosting implementation\"\"\"\n",
    "    model = GradientBoostingClassifier(n_estimators=100, random_state=42)\n",
    "    model.fit(X_train, y_train)\n",
    "    \n",
    "    y_tr = model.predict(X_train)\n",
    "    yPred = model.predict(X_test)\n",
    "    \n",
    "    print(accuracy_score(y_tr, y_train))\n",
    "    print(accuracy_score(yPred, y_test))\n",
    "    \n",
    "    return model, confusion_matrix(y_test, yPred), classification_report(y_test, yPred)\n",
    "\n",
    "print('✓ Simplified model functions defined!')"
   ]
  },
