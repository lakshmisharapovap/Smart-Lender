   "source": [
    "## 5. K-Nearest Neighbors (KNN) Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "a4cca82c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Optimal k value: 5 with score: 0.7396\n",
      "\n",
      "============================================================\n",
      "K-NEAREST NEIGHBORS MODEL PERFORMANCE\n",
      "============================================================\n",
      "Training Accuracy:  0.8104\n",
      "Testing Accuracy:   0.7396\n",
      "Precision:          0.7381\n",
      "Recall:             0.7381\n",
      "F1-Score:           0.7381\n",
      "ROC-AUC Score:      0.7887\n",
      "\n",
      "Confusion Matrix:\n",
      "[[63 22]\n",
      " [22 62]]\n"
     ]
    }
   ],
   "source": [
    "def train_knn(X_train, X_test, y_train, y_test):\n",
    "    \"\"\"Train and evaluate KNN model with optimal k\"\"\"\n",
    "    \n",
    "    # Find optimal k using cross-validation\n",
    "    best_k = 5\n",
    "    best_score = 0\n",
    "    \n",
    "    # Test different k values\n",
    "    k_values = [3, 5, 7, 9, 11, 15, 21]\n",
    "    scores = []\n",
    "    \n",
    "    for k in k_values:\n",
    "        knn_temp = KNeighborsClassifier(n_neighbors=k)\n",
    "        knn_temp.fit(X_train, y_train)\n",
    "        score = knn_temp.score(X_test, y_test)\n",
    "        scores.append(score)\n",
    "        if score > best_score:\n",
    "            best_score = score\n",
    "            best_k = k\n",
    "    \n",
    "    print(f'Optimal k value: {best_k} with score: {best_score:.4f}')\n",
    "    \n",
    "    # Train final model with best k\n",
    "    knn_model = KNeighborsClassifier(n_neighbors=best_k)\n",
    "    knn_model.fit(X_train, y_train)\n",
    "    \n",
    "    # Predictions\n",
    "    y_train_pred = knn_model.predict(X_train)\n",
    "    y_test_pred = knn_model.predict(X_test)\n",
    "    \n",
    "    # Get probabilities for ROC-AUC\n",
    "    y_test_proba = knn_model.predict_proba(X_test)[:, 1]\n",
    "    \n",
    "    # Calculate metrics\n",
    "    train_acc = accuracy_score(y_train, y_train_pred)\n",
    "    test_acc = accuracy_score(y_test, y_test_pred)\n",
    "    precision = precision_score(y_test, y_test_pred)\n",
    "    recall = recall_score(y_test, y_test_pred)\n",
    "    f1 = f1_score(y_test, y_test_pred)\n",
    "    roc_auc = roc_auc_score(y_test, y_test_proba)\n",
    "    \n",
    "    # Confusion matrix\n",
    "    cm = confusion_matrix(y_test, y_test_pred)\n",
    "    \n",
    "    return {\n",
    "        'model': knn_model,\n",
    "        'best_k': best_k,\n",
    "        'train_accuracy': train_acc,\n",
    "        'test_accuracy': test_acc,\n",
    "        'precision': precision,\n",
    "        'recall': recall,\n",
    "        'f1_score': f1,\n",
    "        'roc_auc': roc_auc,\n",
    "        'confusion_matrix': cm,\n",
    "        'y_pred': y_test_pred,\n",
    "        'y_proba': y_test_proba,\n",
    "        'k_values': k_values,\n",
    "        'k_scores': scores\n",
    "    }\n",
    "\n",
    "# Train KNN\n",
    "knn_results = train_knn(X_train, X_test, y_train, y_test)\n",
    "\n",
    "print('\\n' + '='*60)\n",
    "print('K-NEAREST NEIGHBORS MODEL PERFORMANCE')\n",
    "print('='*60)\n",
    "print(f'Training Accuracy:  {knn_results[\"train_accuracy\"]:.4f}')\n",
    "print(f'Testing Accuracy:   {knn_results[\"test_accuracy\"]:.4f}')\n",
    "print(f'Precision:          {knn_results[\"precision\"]:.4f}')\n",
    "print(f'Recall:             {knn_results[\"recall\"]:.4f}')\n",
    "print(f'F1-Score:           {knn_results[\"f1_score\"]:.4f}')\n",
    "print(f'ROC-AUC Score:      {knn_results[\"roc_auc\"]:.4f}')\n",
    "print('\\nConfusion Matrix:')\n",
    "print(knn_results['confusion_matrix'])"
   ]
  },
